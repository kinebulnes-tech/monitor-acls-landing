{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.monitoracls.com" }],
      "destination": "https://monitoracls.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "app.monitoracls.com" }],
      "destination": "https://monitoracls.com/#contacto",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
